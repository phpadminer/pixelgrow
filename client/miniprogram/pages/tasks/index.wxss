.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  position: relative;
}

.header-card {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exp-bank {
  min-width: 180rpx;
  padding: 16rpx;
  border: 2rpx dashed #ffd700;
  border-radius: 8rpx;
  text-align: right;
}

.exp-label {
  display: block;
  font-size: 20rpx;
  color: #c0b38a;
}

.exp-value {
  font-size: 42rpx;
  line-height: 1.1;
  color: #ffd700;
  font-weight: bold;
}

.group-card {
  margin-bottom: 20rpx;
}

.group-title {
  display: block;
  font-size: 30rpx;
  color: #ffd700;
  margin-bottom: 14rpx;
}

.task-card {
  padding: 16rpx;
  border: 2rpx solid #273b62;
  border-radius: 10rpx;
  background: #111c34;
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.task-left {
  width: 64rpx;
}

.task-icon {
  font-size: 44rpx;
}

.task-middle {
  flex: 1;
  padding: 0 12rpx;
}

.task-title {
  display: block;
  font-size: 30rpx;
  color: #f4f6ff;
}

.task-reward {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #a8c0ef;
}

.task-right {
  width: 164rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.task-status {
  font-size: 24rpx;
  color: #88b0ff;
}

.task-status.done {
  color: #8fe18f;
}

.complete-btn {
  background: #ffd700 !important;
  color: #1a1a2e !important;
  font-size: 22rpx !important;
  line-height: 1.8 !important;
  padding: 0 16rpx !important;
}

.state-text {
  text-align: center;
  color: #a8b6d8;
  margin: 18rpx 0;
  font-size: 26rpx;
}

.error-text {
  color: #ff9f9f;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.56);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 88;
}

.modal-card {
  width: 84%;
  background: #17233f;
  border: 4rpx solid #ffd700;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.modal-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.modal-icon {
  font-size: 50rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  color: #f6f7ff;
}

.modal-type {
  display: block;
  font-size: 24rpx;
  color: #8fe18f;
}

.modal-body {
  margin-top: 18rpx;
}

.modal-desc {
  display: block;
  font-size: 27rpx;
  color: #d9e1f5;
  line-height: 1.5;
}

.modal-reward {
  display: block;
  margin-top: 12rpx;
  color: #ffd700;
  font-size: 24rpx;
}

.modal-close {
  margin-top: 20rpx;
}

.exp-fly {
  position: fixed;
  z-index: 120;
  color: #ffd700;
  font-weight: bold;
  font-size: 30rpx;
  text-shadow: 0 0 8rpx rgba(255, 215, 0, 0.8);
  pointer-events: none;
}
